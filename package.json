  "description": "Telegram link shortener bot that sells domain names and phone number leads",
  "main": "js/_index.js",
  "scripts": {
    "start": "node --max-old-space-size=2048 js/start-bot.js",
    "start:dev": "nodemon --node-arg=--max-old-space-size=2048 js/start-bot.js",
    "lint:await": "node scripts/lint_async_in_if.js",
    "lint:lang": "node scripts/check_lang_parity.js && node scripts/check_panel_lang_parity.js",
    "lint:ci": "node scripts/lint_async_in_if.js && node scripts/check_lang_parity.js",
    "test": "jest --testPathPattern=tests/ --testPathIgnorePatterns=node_modules tests/legacy",
    "test:watch": "jest --watch"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@blockbee/api": "^1.1.0",
    "axios": "^1.5.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": ">=4.19.2",
    "form-data": "^4.0.5",
    "jsonwebtoken": "^9.0.3",
    "mongodb": "^5.9.0",
    "multer": "^2.0.2",
    "nanoid": "^3.0.0",
    "node-fetch": "^2.7.0",
    "node-schedule": "^2.1.1",
    "node-telegram-bot-api": "^0.67.0",
    "nodemailer": "^8.0.1",
    "openai": "^6.25.0",
    "puppeteer-core": "^24.37.5",
    "qrcode": "^1.5.3",
    "qrcode-terminal": "^0.12.0",
    "twilio": "^5.12.2",
    "uuid": "^8.3.2",
    "validator": "^13.15.26",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "acorn": "^8.16.0",
    "eslint": "^10.0.1",
    "jest": "29"
  },
  "engines": {
    "node": ">=22.0.0"
  },
